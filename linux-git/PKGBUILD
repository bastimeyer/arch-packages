pkgbase=linux-git
pkgver=6.19.13.r0.gc37bbb1b5317
pkgrel=1
pkgdesc='Linux'
_srctag=v6.19.13
_srcname=linux
_src="git://git.kernel.org/pub/scm/linux/kernel/git/stable/linux.git"
url="https://www.kernel.org/"
arch=(
  x86_64
)
license=(GPL-2.0-only)
makedepends=(
  bc
  binutils
  cpio
  gettext
  glibc
  git
  libelf
  libgcc
  openssl
  pahole
  perl
  python
  rust
  rust-bindgen
  rust-src
  tar
  xxhash
  xz
  zlib
  zstd
)
options=(
  !debug
  !strip
)
source=(
  "${_srcname}::${_src}?signed#tag=${_srctag}"
  '0000-add-sysctl-to-allow-disabling-unprivileged-CLONE_NEWUSER.patch::https://github.com/archlinux/linux/commit/65516c26569069f24bb4676576153c728f4728a8.patch'
  'https://github.com/archlinux/linux/commit/03d048ff0d85018a99595c93494cce2efcf14f24.patch'
  # https://pixelcluster.github.io/VRAM-Mgmt-fixed/
  'dmemcg.patch::https://gitlab.freedesktop.org/pixelcluster/kernel/-/compare/73677a30525a3e42d457039c5ff9af7f90760b04..9260440455cd61f2c90cca172bc9d3e83bf1206d?from_project_id=26726&format=patch'
)
source_x86_64=(
  config.x86_64
)
validpgpkeys=(
  ABAF11C65A2970B130ABE3C479BE3E4300411886  # Linus Torvalds
  647F28654894E3BD457199BE38DBBDC86092693E  # Greg Kroah-Hartman
  E27E5D8A3403A2EF66873BBCDEA66FF797772CDC  # Sasha Levin
)
b2sums=(
  'SKIP'
  277d396eec28fe82079b55514aa9162b73ba4f8a2497b9968c972cd4ce28071fdae2e808392511616883468b3533c0f03452b3f8f7d01eee12a8facf68e5567a
  9ef31d8948ec943b564f0353855d6865dbadb881dd7d4940f0be941ed38faaccbb7df313412e775d81f0fd5dedeade88a2b04ec3e9339f4e52e82ab412e1521a
  bb7fd94f446b330885c9a606c43b38383c5494f2719db41cec02f1440fa34910d7df99021d128230eec43dba58cb6f4d576026d3321ecdf9cf9a7a5477de383e
